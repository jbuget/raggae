# =============================================================================
# RAGGAE — Server Environment Variables Template
# Copy this file to .env and fill in the values.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=raggae
POSTGRES_PASSWORD=change_me
POSTGRES_DB=raggae
# DATABASE_URL is used by the Python application
DATABASE_URL=postgresql+asyncpg://raggae:change_me@localhost/raggae

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me
S3_BUCKET_NAME=raggae-documents
S3_REGION=us-east-1
S3_SECURE=false

# --- Security ---
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me
# Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
USER_PROVIDER_KEYS_ENABLED=true

# --- Networking ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
FRONTEND_URL=http://localhost:3000
SERVER_PORT=8000
UVICORN_WORKERS=2

# --- Backends & Mode ---
# postgres | inmemory
PERSISTENCE_BACKEND=postgres
# s3 | inmemory
STORAGE_BACKEND=s3
# sync | async | off
PROCESSING_MODE=async
# native | llamaindex
TEXT_CHUNKER_BACKEND=native

# --- Default LLM provider (openai | gemini | ollama | inmemory) ---
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o-mini
LLM_REQUEST_TIMEOUT_SECONDS=120

# --- Default Embedding provider (openai | gemini | ollama | inmemory) ---
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_API_KEY=
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# --- Chunking configuration ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
DEFAULT_PARENT_CHILD_CHUNKING=true

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=10m

# --- Retrieval / Reranking ---
RETRIEVAL_DEFAULT_STRATEGY=hybrid
RETRIEVAL_MIN_SCORE=0.3
RETRIEVAL_DEFAULT_CHUNK_LIMIT=8
RETRIEVAL_CONTEXT_WINDOW_SIZE=1
RETRIEVAL_VECTOR_WEIGHT=0.6
RETRIEVAL_FULLTEXT_WEIGHT=0.4
RETRIEVAL_CANDIDATE_MULTIPLIER=5
RETRIEVAL_FULLTEXT_LANGUAGE=french
# none | cross_encoder | mmr
RERANKER_BACKEND=none
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_CANDIDATE_MULTIPLIER=3

# --- Chat history ---
CHAT_HISTORY_WINDOW_SIZE=8
CHAT_HISTORY_MAX_CHARS=4000

# --- Email (Mailgun) ---
# "noop" = no emails sent (default) | "mailgun" = send via Mailgun API
EMAIL_BACKEND=noop
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=noreply@raggae.app
MAILGUN_APP_NAME=Raggae
# US region: https://api.mailgun.net/v3 | EU region: https://api.eu.mailgun.net/v3
MAILGUN_API_BASE=https://api.mailgun.net/v3

# --- SSO Microsoft Entra ID ---
ENTRA_ENABLED=false
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=http://localhost:8000/api/v1/auth/entra/callback
# JSON list of allowed email domains, e.g. ["waat.fr","example.com"]
ENTRA_ALLOWED_DOMAINS=[]
ENTRA_SINGLE_LOGOUT=false
ENTRA_CLIENT_SECRET_EXPIRES_AT=

# --- Upload limits ---
MAX_UPLOAD_SIZE=104857600
MAX_UPLOAD_FILES_PER_REQUEST=20
MAX_DOCUMENTS_PER_PROJECT=100
